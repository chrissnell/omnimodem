# omnimodem — udev rules for locally-attached RTL2832U SDR dongles.
#
# Grants the logged-in desktop user read/write access to any recognized RTL-SDR
# dongle so omnimodem can claim the USB interface directly (pure-Rust nusb, no
# C driver). Without this, only root can open the device on most distros.
#
# Install:
#   sudo cp packaging/udev/99-omnimodem-rtlsdr.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules && sudo udevadm trigger
#   # then re-plug the dongle.
#
# TAG+="uaccess" hands access to the active seat's user via systemd-logind ACLs;
# MODE="0660" is the fallback for systems without uaccess. The id list mirrors
# RTL_USB_IDS in crates/omnimodem/src/device/enumerate.rs — keep them in sync.
#
# NOTE: these rules only govern *permissions*. If the kernel DVB-T driver
# (dvb_usb_rtl28xxu) grabs the dongle first, blacklist it — see docs/running.md.

# Generic RTL2832U
SUBSYSTEM=="usb", ATTR{idVendor}=="0bda", ATTR{idProduct}=="2832", MODE="0660", TAG+="uaccess"
# Generic RTL2832U OEM (most common blog-v3 dongles)
SUBSYSTEM=="usb", ATTR{idVendor}=="0bda", ATTR{idProduct}=="2838", MODE="0660", TAG+="uaccess"
# DigitalNow Quad DVB-T PCI-E card
SUBSYSTEM=="usb", ATTR{idVendor}=="0413", ATTR{idProduct}=="6680", MODE="0660", TAG+="uaccess"
# Leadtek WinFast DTV Dongle mini D
SUBSYSTEM=="usb", ATTR{idVendor}=="0413", ATTR{idProduct}=="6f0f", MODE="0660", TAG+="uaccess"
# Genius TVGo DVB-T03 USB dongle (Ver. B)
SUBSYSTEM=="usb", ATTR{idVendor}=="0458", ATTR{idProduct}=="707f", MODE="0660", TAG+="uaccess"
# Terratec Cinergy T Stick Black (rev 1)
SUBSYSTEM=="usb", ATTR{idVendor}=="0ccd", ATTR{idProduct}=="00a9", MODE="0660", TAG+="uaccess"
